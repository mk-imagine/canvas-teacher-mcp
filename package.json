{
  "name": "canvas-mcp",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w packages/core && npm run build -w packages/teacher",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "npm run test --workspaces --if-present",
    "test:integration": "node --no-warnings node_modules/vitest/vitest.mjs run --config packages/teacher/vitest.integration.config.ts",
    "test:unit:coverage": "npm run test:coverage --workspaces --if-present",
    "test:integration:coverage": "node --no-warnings node_modules/vitest/vitest.mjs run --coverage --config packages/teacher/vitest.integration.config.ts",
    "test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage",
    "seed": "tsx scripts/seed-test-data.ts",
    "count-tokens": "tsx scripts/count-tokens.ts",
    "postinstall": "patch-package"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@canvas-mcp/core": "*",
    "@canvas-mcp/teacher": "*",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "dotenv": "^16.0.0",
    "istanbul-merge": "^2.0.0",
    "msw": "^2.0.0",
    "nyc": "^18.0.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
